rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNÇÕES AUXILIARES ---
    
    // Verifica se o usuário é o dono do documento (pelo ID do Auth)
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Verifica se é Admin (lê o campo role do banco de dados)
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Verifica se é Profissional
    function isProfessional() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'professional';
    }

    function isMemberOfGroup(groupId) {
      return request.auth != null &&
             request.auth.uid in get(/databases/$(database)/documents/grupos/$(groupId)).data.participants;
    }

    // --- REGRAS DA COLEÇÃO DE USUÁRIOS ---
    match /users/{userId} {
      // Leitura: Todos logados podem ler perfis básicos (essencial para renderizar nomes em grupos/chat)
      allow read: if request.auth != null;
      
      // Criação: Só o próprio usuário pode criar seu perfil no primeiro login
      allow create: if isOwner(userId);
      
      // Atualização: O dono pode editar seus dados, MAS...
      // A regra abaixo impede que ele mude o campo 'role' ou 'isAdmin' para tentar virar admin
      allow update: if isOwner(userId) 
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isAdmin']));

      // --- SUBCOLEÇÕES DO USUÁRIO (Mood Tracker, Quiz, Conquistas, Notificações) ---
      // A sintaxe {document=**} libera qualquer subcoleção aninhada dentro do usuário
      match /{document=**} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // --- REGRAS DA COLEÇÃO DE PACIENTES ---
    match /patients/{patientId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin() || isProfessional();
    }

    // --- REGRAS PARA GRUPOS E MATERIAIS ---
    match /grupos/{groupId} {
      // Todos os usuários logados podem ver os grupos (para listar na Dashboard)
      allow read: if request.auth != null;
      
      // Apenas Profissionais e Admins podem criar ou editar grupos
      allow create, update, delete: if isAdmin() || isProfessional();
      
      // Subcoleções de grupos (ex: chat, posts)
      match /{document=**} {
        allow read: if request.auth != null;
        allow write: if isMemberOfGroup(groupId) || isAdmin() || isProfessional();
      }
    }

    match /sessions/{sessionId} {
      allow read, write: if isAdmin() || isProfessional();
    }

    match /appointments/{appointmentId} {
      allow read: if isAdmin() || isProfessional() ||
                   (request.auth != null &&
                    (
                      request.auth.uid == resource.data.patientId ||
                      request.auth.uid == resource.data.userId
                    ));
      allow create, update, delete: if isAdmin() || isProfessional();
    }

    match /referrals/{referralId} {
      allow read: if isAdmin() || isProfessional() ||
                   (request.auth != null && request.auth.uid == resource.data.patientId);
      allow create, update, delete: if isAdmin() || isProfessional();
    }

    match /tobacco_anamnesis/{anamnesisId} {
      allow read: if isAdmin() || isProfessional() ||
                   (request.auth != null && request.auth.uid == resource.data.patientId);
      allow create, update, delete: if isAdmin() || isProfessional() ||
                                     (request.auth != null && request.auth.uid == request.resource.data.patientId);
    }

    match /materials/{materialId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || isProfessional();
    }

    // --- REGRAS PARA DIAGNÓSTICO DE SAÚDE (System Health) ---
    match /_health_check/{docId} {
      allow read, write: if isAdmin();
    }

    // Regra padrão de negação (segurança por padrão)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
