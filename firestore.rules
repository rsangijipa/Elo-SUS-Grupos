rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Função auxiliar para verificar se é admin
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Regras para a coleção de usuários
    match /users/{userId} {
      // Qualquer logado pode ler perfis (necessário para grupos, mural, etc)
      allow read: if request.auth != null;
      
      // O usuário só pode criar/editar SE o ID do documento for igual ao UID dele
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Permite atualizar dados (como avatar, telefone), mas BLOQUEIA mudar o campo 'role'
      allow update: if request.auth != null 
                    && request.auth.uid == userId
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
    }

    // Regras para Grupos e Chat
    match /grupos/{groupId} {
      // Qualquer usuário autenticado pode ler os grupos (para listar, etc)
      // Idealmente, restringir apenas aos participantes, mas para MVP 'read' geral é aceitável ou verificar array participants
      allow read: if request.auth != null;
      
      // Apenas admin ou profissionais podem criar/editar grupos (simplificado para auth != null por enquanto se não houver role check estrito no front)
      allow write: if request.auth != null; 

      // Subcoleção de mensagens
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }
    
    // Regras genéricas para outras coleções se necessário, mas EVITAR 'match /{document=**}'
  }
}
