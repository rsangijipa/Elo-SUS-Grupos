rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Função auxiliar para verificar se é admin
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // --- REGRAS DE USUÁRIOS (SECURE) ---
    match /users/{userId} {
      // Qualquer logado pode ler perfis (necessário para grupos, mural, etc)
      allow read: if request.auth != null;
      
      // O usuário só pode criar/editar SE o ID do documento for igual ao UID dele
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Permite atualizar dados, mas BLOQUEIA mudar o campo 'role' (a menos que seja Admin)
      allow update: if (request.auth != null && request.auth.uid == userId && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']))) 
                    || isAdmin();
                    
      // Admin pode fazer tudo
      allow write: if isAdmin();
    }

    // --- REGRAS DE GRUPOS E CHAT ---
    match /grupos/{groupId} {
      allow read, write: if request.auth != null;
      
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }

    // --- OUTRAS COLEÇÕES (Permissivas para Dev) ---
    // Adicione aqui outras coleções conforme necessário
    match /daily_logs/{document=**} { allow read, write: if request.auth != null; }
    match /mood_logs/{document=**} { allow read, write: if request.auth != null; }
    match /appointments/{document=**} { allow read, write: if request.auth != null; }
    match /referrals/{document=**} { allow read, write: if request.auth != null; }
    match /tobacco_anamnesis/{document=**} { allow read, write: if request.auth != null; }
    match /gamification/{document=**} { allow read, write: if request.auth != null; }
    match /feedback/{document=**} { allow read, write: if request.auth != null; }
    
  }
}
