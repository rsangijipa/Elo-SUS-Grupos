rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isProfessional() {
      return isAuthenticated() && (request.auth.token.role == 'professional' || getUserData().role == 'professional');
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Patients - Strict Access
    match /pacientes/{patientId} {
      // Read: Only the patient themselves OR a professional
      allow read: if isAuthenticated() && (request.auth.uid == patientId || isProfessional());
      // Write: ONLY professionals
      allow write: if isProfessional();
    }

    // Groups
    match /grupos/{groupId} {
      // Read: Authenticated users (Patients need to see groups they are in, Professionals see all)
      allow read: if isAuthenticated();
      // Write: ONLY professionals
      allow write: if isProfessional();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
