rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'admin';
    }

    function isProfessional() {
      return isAuthenticated() && (getUserData().role == 'professional' || getUserData().role == 'admin');
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users: 
    // - Admin can read/write all.
    // - Professionals can read all (to find patients), but write only their own? 
    //   Actually user said: "Profissional pode apenas ler (para buscar pacientes)."
    // - Users can read/write their own profile.
    match /users/{userId} {
      allow read: if isOwner(userId) || isProfessional();
      allow write: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      // Notifications sub-collection
      match /notifications/{notificationId} {
        allow read, write: if isOwner(userId);
        // Allow professionals/admin to write notifications to other users?
        // The service uses 'addDoc' to 'users/{userId}/notifications'.
        // If the sender is a professional adding a participant, they need write access to the patient's notifications.
        allow create: if isProfessional(); 
      }
    }

    // Groups: 
    // - Admin and Professional can read and write (create/delete).
    // - Patients might need read access if they are in the group? 
    //   For now, let's stick to the request: "Admin e Profissional podem ler e escrever".
    match /grupos/{groupId} {
      allow read: if isProfessional();
      allow write: if isProfessional();

      // Sessions sub-collection
      match /sessions/{sessionId} {
        allow read, write: if isProfessional();
      }
    }

    // Patients Collection (if separate from users, but usually linked):
    // "Pacientes": Visible to admin (and potentially professional for read-only).
    // Request says: "users: Admin pode criar/deletar qualquer um. Profissional pode apenas ler".
    // Assuming 'pacientes' collection is used for patient records distinct from auth users?
    // The code uses 'pacientes' collection in some places and 'users' in others. 
    // Let's secure 'pacientes' too.
    match /pacientes/{patientId} {
      allow read: if isProfessional();
      allow write: if isAdmin(); // Only admin can add/delete patients? 
      // Wait, user said: "Profissional... Pode: Criar/Excluir Grupos e Adicionar/Remover Participantes".
      // But for "Pacientes" menu: "Pode ver/usar: Menu 'Pacientes'".
      // And "Admin... Pode: Adicionar/Excluir Profissionais, Pacientes e Grupos".
      // So Professionals might NOT be able to create patients directly, only Admins?
      // Let's assume Professionals can READ patients to add them to groups.
      // But if they need to create a patient on the fly?
      // The prompt says: "Admin... Pode: Adicionar/Excluir ... Pacientes". 
      // "Profissional... NÃO PODE: Excluir contas...".
      // Let's allow Professional to write to 'pacientes' if it's just updating?
      // Let's stick to: Admin = RW, Professional = Read.
      allow create, update: if isAdmin(); 
      allow delete: if isAdmin();
    }

    // Attendance (if top level, but we moved it to subcollection):
    // "attendance: Admin e Profissional podem gravar."
    // We handled this in groups/{groupId}/sessions.
    
    // Referrals
    match /referrals/{referralId} {
      allow read, write: if isProfessional();
    }
  }
}
